generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  currency     String        @default("USD")
  createdAt    DateTime      @default(now())
  categories   Category[]
  transactions Transaction[]
}

model Category {
  id           String        @id @default(cuid())
  userId       String
  name         String
  type         String        // "INCOME" or "COST"
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name, type])
}

model Transaction {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  type       String   // "INCOME" or "COST"
  amountCents Int     // stored as cents to avoid floating point
  date       String   // YYYY-MM-DD format for timezone safety
  note       String   @default("")
  excluded   Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([userId, date])
  @@index([userId, type])
}
